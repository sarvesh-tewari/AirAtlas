# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored — NEVER commit real keys.
# These same names must be set as GitHub Actions repository secrets
# (Settings → Secrets and variables → Actions).

# data.gov.in — CPCB "Real time Air Quality Index from various locations"
DATA_GOV_IN_KEY=

# OpenAQ v3 API key (historical data)
OPENAQ_API_KEY=

# Open-Meteo needs no key.
