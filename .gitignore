#     source files (station_city_overrides.json, city_aliases.json) are NOT ignored. ---
data/history/*.parquet
data/recent/*.parquet
data/live/*.json
data/meta/city_list.json
data/meta/coverage.json
data/meta/station_city_map.json
data/meta/unmapped_stations.json
